# ZONER API Authentication
ZONER_API_TOKEN=your_api_token_here

# Push Notification Service Type (e.g., discord, slack, pushover, firebase, webhook)
PUSH_SERVICE_TYPE=discord

# Push Notification Service URL (e.g., Discord webhook URL)
PUSH_SERVICE_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Push Token (only needed for some services like Pushover, Firebase, generic webhook with auth)
PUSH_TOKEN=your_push_token_here

# Domains to Monitor (comma-separated)
DOMAINS_TO_MONITOR=example.com,mysite.cz
