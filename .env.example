# Push Notification Service Type (e.g., discord, slack, pushover, firebase, webhook)
PUSH_SERVICE_TYPE=discord

# Push Notification Service URL (e.g., Discord webhook URL)
PUSH_SERVICE_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Push Token (api_token for Pushover, server_key for Firebase, access_token for Pushbullet, auth_token for generic webhook)
# Leave empty for Discord/Slack
PUSH_TOKEN=

# Pushover User Key (only for PUSH_SERVICE_TYPE=pushover)
PUSHOVER_USER_KEY=

# Firebase Device Token (optional, for PUSH_SERVICE_TYPE=firebase if sending to specific device)
FCM_DEVICE_TOKEN=

# Domains to Monitor (comma-separated)
DOMAINS_TO_MONITOR=karlik.cz,karlik.com,karlik.eu,karlik.net
