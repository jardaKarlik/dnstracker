{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python dns_watchdog_agent.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "variables": [
    "ZONER_API_TOKEN",
    "PUSH_SERVICE_TYPE",
    "PUSH_SERVICE_URL",
    "PUSH_TOKEN",
    "DOMAINS_TO_MONITOR"
  ]
}
